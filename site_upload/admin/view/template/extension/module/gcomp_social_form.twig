{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-social" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ form_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>{% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}<div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}</div>{% endif %}
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-pencil"></i> {{ form_title }}</h3></div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" id="form-social" class="form-horizontal">
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_type }}</label>
            <div class="col-sm-10"><input type="text" name="type" value="{{ type }}" class="form-control" required></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_label_ka }}</label>
            <div class="col-sm-10"><input type="text" name="label_ka" value="{{ label_ka }}" class="form-control"></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_label_en }}</label>
            <div class="col-sm-10"><input type="text" name="label_en" value="{{ label_en }}" class="form-control"></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_label_ru }}</label>
            <div class="col-sm-10"><input type="text" name="label_ru" value="{{ label_ru }}" class="form-control"></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_icon }}</label>
            <div class="col-sm-10"><input type="text" name="icon" value="{{ icon }}" class="form-control" placeholder="fa-viber"></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_url }}</label>
            <div class="col-sm-10"><input type="text" name="url" value="{{ url }}" class="form-control" placeholder="https://..."></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_phone }}</label>
            <div class="col-sm-10"><input type="text" name="phone" value="{{ phone }}" class="form-control"></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_email }}</label>
            <div class="col-sm-10"><input type="text" name="email" value="{{ email }}" class="form-control"></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_color }}</label>
            <div class="col-sm-10"><input type="text" name="color" value="{{ color }}" class="form-control" placeholder="#0084ff"></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_position }}</label>
            <div class="col-sm-10">
              <select name="position" class="form-control">
                <option value="header"   {% if position == 'header' %}selected{% endif %}>{{ text_position_header }}</option>
                <option value="floating" {% if position == 'floating' %}selected{% endif %}>{{ text_position_floating }}</option>
                <option value="both"     {% if position == 'both' %}selected{% endif %}>{{ text_position_both }}</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_sort_order }}</label>
            <div class="col-sm-10"><input type="number" name="sort_order" value="{{ sort_order ? sort_order : 0 }}" class="form-control"></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="status" class="form-control">
                <option value="1" {% if status == '1' or status == 1 %}selected{% endif %}>{{ text_enabled }}</option>
                <option value="0" {% if status == '0' or status == 0 %}selected{% endif %}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
